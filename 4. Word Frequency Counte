import re
from collections import defaultdict

# 1. Define a passage
passage = (
    "This is a sample passage. It contains several words, some of which are repeated. "
    "We will count the frequency of each word in this passage. This passage is interesting."
)

print("Original Passage:\n", passage)

# Preprocessing: convert to lowercase, remove punctuation, and split into words
# Remove punctuation and numbers
cleaned_passage = re.sub(r'[^a-zA-Z\s]', '', passage).lower()
words = cleaned_passage.split()

# 2. Count how often each word appears using a dictionary
word_counts = defaultdict(int)
for word in words:
    if word:
        word_counts[word] += 1

