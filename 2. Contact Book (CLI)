def run_contact_book_cli():
    """Runs the command-line interface for the contact book."""
    while True:
        print("\n--- Contact Book Menu ---")
        print("1. Add Contact")
        print("2. Search Contact")
        print("3. Update Contact")
        print("4. Delete Contact")
        print("5. List All Contacts")
        print("6. Check for Duplicate Numbers")
        print("7. Exit")

        choice = input("Enter your choice: ")

        if choice == '1':
            name = input("Enter contact name: ").strip()
            phone = input("Enter phone number: ").strip()
            email = input("Enter email (optional): ").strip()
            add_contact(name, phone, email if email else None)
        elif choice == '2':
            name = input("Enter name to search: ").strip()
            contact = search_contact(name)
            if contact:
                print(f"Name: {name}, Phone: {contact['phone']}, Email: {contact['email']}")
            else:
                print(f"Contact '{name}' not found.")
        elif choice == '3':
            name = input("Enter name to update: ").strip()
            if name not in contacts:
                print(f"Contact '{name}' not found.")
                continue
            current_phone = contacts[name]['phone']
            current_email = contacts[name]['email']
            print(f"Current Phone: {current_phone}, Current Email: {current_email}")
            new_phone = input(f"Enter new phone number (leave blank for {current_phone}): ").strip()
            new_email = input(f"Enter new email (leave blank for {current_email}): ").strip()
            update_contact(name, new_phone if new_phone else None, new_email if new_email else None)
        elif choice == '4':
            name = input("Enter name to delete: ").strip()
            delete_contact(name)
        elif choice == '5':
            if not contacts:
                print("Contact book is empty.")
            else:
                print("\n--- All Contacts ---")
                for name, details in contacts.items():
                    print(f"Name: {name}, Phone: {details['phone']}, Email: {details['email']}")
        elif choice == '6':
            check_for_duplicate_numbers()
        elif choice == '7':
            print("Exiting Contact Book. Goodbye!")
            break
        else:
            print("Invalid choice. Please try again.")

