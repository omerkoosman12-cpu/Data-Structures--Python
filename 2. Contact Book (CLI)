def add_contact(name, phone, email=None):
    """Adds a new contact to the contact book."""
    if name in contacts:
        print(f"Error: Contact '{name}' already exists.")
        return
    if phone in phone_numbers_set:
        print(f"Warning: Phone number {phone} is already associated with another contact.")
        # Optionally, you could prevent adding or ask for confirmation here.

    contacts[name] = {'phone': phone, 'email': email}
    phone_numbers_set.add(phone)
    print(f"Contact '{name}' added successfully.")

def search_contact(name):
    """Searches for a contact by name and returns their details."""
    if name in contacts:
        return contacts[name]
    else:
        return None

def update_contact(name, new_phone=None, new_email=None):
    """Updates an existing contact's phone number or email."""
    if name not in contacts:
        print(f"Error: Contact '{name}' not found.")
        return

    old_phone = contacts[name]['phone']
    if new_phone and new_phone != old_phone:
        if new_phone in phone_numbers_set:
            print(f"Warning: New phone number {new_phone} is already in use by another contact.")
            # Decide if you want to proceed or stop
        else:
            phone_numbers_set.remove(old_phone) # Remove old number from set
            phone_numbers_set.add(new_phone)     # Add new number to set
            contacts[name]['phone'] = new_phone
            print(f"Phone number for '{name}' updated to {new_phone}.")
    elif new_phone == old_phone:
        print(f"Phone number for '{name}' is already {new_phone}.")

    if new_email is not None:
        contacts[name]['email'] = new_email
        print(f"Email for '{name}' updated to {new_email}.")

    if not new_phone and new_email is None:
        print(f"No updates provided for '{name}'.")

def delete_contact(name):
    """Deletes a contact from the contact book."""
    if name in contacts:
        phone_to_remove = contacts[name]['phone']
        del contacts[name]
        if phone_to_remove in phone_numbers_set:
            phone_numbers_set.remove(phone_to_remove)
        print(f"Contact '{name}' deleted successfully.")
    else:
        print(f"Error: Contact '{name}' not found.")

